# 本地 MinIO（与 docker-compose.yml 一致）
STORAGE_ENDPOINT=http://localhost:9100
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin123
STORAGE_BUCKET=lost-found-images
STORAGE_PUBLIC_URL=http://localhost:8080/api/files/public
STORAGE_PATH_STYLE=true

# Cloudflare R2 生产环境
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=lost-found-images
R2_PUBLIC_URL=https://<PUBLIC_BUCKET_DOMAIN>
