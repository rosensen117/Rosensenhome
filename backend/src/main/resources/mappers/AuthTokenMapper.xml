<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shiguang.lostfound.auth.AuthTokenMapper">
    <resultMap id="userMap" type="UserAccount">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="studentId" column="student_id"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="role" column="role" javaType="com.shiguang.lostfound.auth.Role"/>
        <result property="verified" column="verified"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="AuthToken" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO auth_tokens (user_id, token_hash, expires_at, created_at)
        VALUES (#{userId}, #{tokenHash}, #{expiresAt}, #{createdAt})
    </insert>

    <select id="findUserByValidTokenHash" resultMap="userMap">
        SELECT u.id, u.name, u.student_id, u.phone, u.email, u.password_hash,
               u.role, u.verified, u.created_at
        FROM auth_tokens t
        INNER JOIN users u ON u.id = t.user_id
        WHERE t.token_hash = #{tokenHash} AND t.expires_at &gt; CURRENT_TIMESTAMP
    </select>

    <delete id="deleteByTokenHash">
        DELETE FROM auth_tokens WHERE token_hash = #{tokenHash}
    </delete>
</mapper>
